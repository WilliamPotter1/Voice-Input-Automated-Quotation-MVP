{
  "version": 2,
  "framework": null,
  "buildCommand": "npm run build",
  "installCommand": "npm install --loglevel=error",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/", "destination": "/api" }
  ],
  "functions": {
    "api/[[...path]].ts": {
      "memory": 1024,
      "maxDuration": 10
    }
  }
}
