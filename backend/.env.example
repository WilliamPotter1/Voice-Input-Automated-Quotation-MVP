# Set these in Vercel: Project → Settings → Environment Variables.
# For local runs use: put a .env in this folder and run `npm run dev` (vercel dev).

# OpenAI (Whisper + GPT quote extraction)
OPENAI_API_KEY=sk-your-openai-api-key

# MongoDB
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/voice_quote_db?retryWrites=true&w=majority"

# JWT (use a long random string in production)
JWT_SECRET=your-jwt-secret-change-in-production

# CORS: frontend origin (optional; empty = allow all)
# CORS_ORIGIN=https://your-frontend.vercel.app
